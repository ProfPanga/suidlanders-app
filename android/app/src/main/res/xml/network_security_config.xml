<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow all cleartext HTTP traffic for offline camp LAN scenario -->
    <!-- This is safe because: -->
    <!-- 1. App operates on isolated camp WiFi networks (no internet) -->
    <!-- 2. Physical network security (camp perimeter) -->
    <!-- 3. Data encrypted at rest in local database -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
